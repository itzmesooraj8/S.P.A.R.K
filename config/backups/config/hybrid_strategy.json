{
  "name": "SPARK Hybrid Brain Strategy",
  "description": "Model tiering and fallback map for hybrid cloud/local execution.",
  "tiers": [
    {
      "tier": 0,
      "name": "Groq Core Gateway Engine",
      "model_env": "GROQ_MODEL",
      "default_model": "llama-3.3-70b-versatile",
      "role": "primary_cloud",
      "behavior": "high-capacity reasoning, full manifest compilation, schema outputs"
    },
    {
      "tier": 1,
      "name": "Ollama Tier-1 Local Edge",
      "model_env": "OLLAMA_MODEL_TIER1",
      "default_model": "gemma3:4b",
      "role": "local_edge_high_logic",
      "behavior": "safe localized reasoning, prioritized logic, token-controlled execution"
    },
    {
      "tier": 2,
      "name": "Ollama Tier-2 Local Edge",
      "model_env": "OLLAMA_MODEL_TIER2",
      "default_model": "gemma4",
      "role": "local_edge_structural",
      "behavior": "structure parsing, determinisitic transformations"
    },
    {
      "tier": 3,
      "name": "Ollama Tier-3 Mini Edge",
      "model_env": "OLLAMA_MODEL_TIER3",
      "default_model": "qwen2.5:1.5b",
      "role": "emergency_mini",
      "behavior": "minimal argument parsing, low-overhead outputs"
    }
  ],
  "handoff_rules": {
    "rate_limit_status_codes": [429],
    "timeout_seconds": 30,
    "handshake_state_keys": ["session_id","tracking_matrix","last_response_partial"],
    "max_local_tokens": 1024
  }
}
