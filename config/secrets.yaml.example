# This is an example secrets file.
# Copy this to secrets.yaml and fill in your keys.
# DO NOT COMMIT secrets.yaml to git.

keys:
  google_gemini: ""
  deepgram: ""
  openai: ""

# ── Combat Mode API keys (optional — features gracefully degrade without them) ──
combat:
  # Shodan — passive recon (https://account.shodan.io)
  shodan_api_key: ""
  # Hunter.io — email OSINT (https://hunter.io/api)
  hunter_api_key: ""
  # Have I Been Pwned — breach lookup (https://haveibeenpwned.com/API/v3)
  hibp_api_key: ""
  # GreyNoise — IP context in SIGINT feeds (https://www.greynoise.io)
  greynoise_api_key: ""
  # Tor SOCKS5 proxy (leave default if running local Tor Browser / tor daemon)
  tor_socks5_host: "127.0.0.1"
  tor_socks5_port: 9050
