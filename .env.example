# ============================================================================
#  S.P.A.R.K — Environment Variables Reference
#  Copy this file to .env and fill in:
#    cp .env.example .env
#
#  Lines marked [REQUIRED] must be set for that feature to work.
#  Lines marked [OPTIONAL] have sensible defaults or a free-data fallback.
#  Lines marked [SECURITY] will use a weak default if not set — always set
#  these in production.
# ============================================================================

# ─── Core Server ─────────────────────────────────────────────────────────────
SPARK_HOST="0.0.0.0"
SPARK_PORT="8000"
SPARK_WORKSPACE_DIR=""          # leave blank → uses project root
LOG_LEVEL="info"

# ─── [SECURITY] JWT Authentication ───────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SPARK_JWT_SECRET=""             # [SECURITY] 32+ byte random hex string

# ─── [SECURITY] Default Root User ────────────────────────────────────────────
# Used only when no users are defined in config/secrets.yaml.
# If both blank, a temporary password is derived from the hostname and logged.
SPARK_ROOT_USER="root"
SPARK_ROOT_PASSWORD=""          # [SECURITY] set a strong password

# ─── [SECURITY] External Webhooks (Telegram / WhatsApp / Generic) ──────────
# Shared HMAC secret used for X-SPARK-Signature / X-Hub-Signature-256.
SPARK_WEBHOOK_SECRET=""         # [SECURITY] required for production webhook ingress
SPARK_ALLOW_UNSIGNED_WEBHOOKS="false"  # [SECURITY] set true only for local testing
SPARK_TELEGRAM_SECRET_TOKEN=""  # [OPTIONAL] Telegram header verification token
SPARK_WHATSAPP_VERIFY_TOKEN=""  # [OPTIONAL] WhatsApp GET verification token

# ─── Outbound Social Adapters (reply delivery) ──────────────────────────────
TELEGRAM_BOT_TOKEN=""           # [OPTIONAL] required to send Telegram replies
WHATSAPP_ACCESS_TOKEN=""        # [OPTIONAL] required to send WhatsApp replies
WHATSAPP_PHONE_NUMBER_ID=""     # [OPTIONAL] default sender phone number id
WHATSAPP_GRAPH_API_VERSION="v21.0"  # [OPTIONAL] Meta Graph API version

# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=""               # [OPTIONAL] enables GPT-4o / GPT-4o-mini
ANTHROPIC_API_KEY=""            # [OPTIONAL] enables Claude Haiku / Sonnet
GOOGLE_API_KEY=""               # [OPTIONAL] enables Gemini 2.0 Flash / Pro
GEMINI_API_KEY=""               # [OPTIONAL] alias for GOOGLE_API_KEY

OLLAMA_HOST="http://localhost:11434"  # [OPTIONAL] change if Ollama on a remote host
OLLAMA_MODEL="llama3:8b"        # default model for local generation

# ─── LLM Runtime Guards (OOM/overload protection) ───────────────────────────
SPARK_MAX_INPUT_CHARS="8000"            # reject very large inbound messages
SPARK_MAX_SYSTEM_PROMPT_CHARS="12000"   # trim oversized system prompts
SPARK_MAX_TOTAL_PROMPT_CHARS="18000"    # total prompt budget before truncation
SPARK_OLLAMA_MAX_TOKENS="1024"          # hard generation cap per request
SPARK_MEMORY_PRESSURE_PCT="92"          # pause generation above this RAM usage

# ─── Voice ───────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=""           # [OPTIONAL] enables ElevenLabs TTS voice synthesis
SPARK_WHISPER_MODEL="small"     # [OPTIONAL] faster-whisper model size
SPARK_WHISPER_DEVICE="auto"     # [OPTIONAL] auto | cpu | cuda
SPARK_WHISPER_COMPUTE_TYPE="auto"  # [OPTIONAL] auto | int8 | float16
SPARK_STT_LANGUAGE="en"         # [OPTIONAL] default STT language

SPARK_TTS_ENGINE="piper"        # [OPTIONAL] piper | edge-tts
SPARK_PIPER_BINARY="piper"      # [OPTIONAL] piper CLI path
SPARK_PIPER_MODEL_PATH=""       # [OPTIONAL] required for offline Piper mode
SPARK_PIPER_CONFIG_PATH=""      # [OPTIONAL] Piper model config path
SPARK_TTS_VOICE="en-US-GuyNeural"   # [OPTIONAL] edge-tts fallback voice
SPARK_TTS_RATE="+0%"            # [OPTIONAL] edge-tts fallback rate
SPARK_TTS_PITCH="+0Hz"          # [OPTIONAL] edge-tts fallback pitch

# ─── Semantic Memory / RAG ───────────────────────────────────────────────────
SPARK_CHROMA_DIR=""             # [OPTIONAL] custom persistent directory for Chroma

# ─── Sandbox Runtime ─────────────────────────────────────────────────────────
SPARK_SANDBOX_MODE="auto"       # [OPTIONAL] auto | docker | local
SPARK_SANDBOX_TIMEOUT_SEC="60"  # [OPTIONAL] command timeout for sandbox execution

# ─── Globe Intelligence — Conflict ───────────────────────────────────────────
# ACLED (Armed Conflict Location & Event Data)
# Free for researchers & journalists. Register at: https://acleddata.com/
ACLED_ACCESS_TOKEN=""
ACLED_EMAIL=""

# ─── Globe Intelligence — Market ─────────────────────────────────────────────
# Finnhub — free tier: 60 req/min. https://finnhub.io/
FINNHUB_API_KEY=""
# U.S. Energy Information Administration — free. https://www.eia.gov/opendata/
EIA_API_KEY=""

# ─── Globe Intelligence — Wildfire ───────────────────────────────────────────
# NASA FIRMS — free. https://firms.modaps.eosdis.nasa.gov/
NASA_FIRMS_API_KEY=""

# NewsData.io — real-time & historical news (paid). https://newsdata.io/
# When set: replaces GDELT as the primary source for /api/news/v1/listNewsArticles
NEWSDATA_API_KEY=""

# ─── Globe Intelligence — Internet Outage ────────────────────────────────────
# Cloudflare Radar — free (requires Cloudflare account). https://developers.cloudflare.com/radar/
CLOUDFLARE_API_TOKEN=""

# ─── Globe Intelligence — Aviation ───────────────────────────────────────────
# OpenSky Network — higher rate limits vs anonymous. https://opensky-network.org/
OPENSKY_CLIENT_ID=""
OPENSKY_CLIENT_SECRET=""

# ─── Desktop Agent ───────────────────────────────────────────────────────────
SPARK_AGENT_PORT="7700"         # [OPTIONAL] local Desktop Agent service port

# ─── Frontend Dev Flags ───────────────────────────────────────────────────────
# Set to "true" to print WebSocket lifecycle events (connect / reconnect / error)
# to the browser console. Off by default to keep console clean when backend is offline.
VITE_VERBOSE_WS="false"         # [OPTIONAL]  true | false
