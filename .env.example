# SPARK AI Backend
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
ELEVENLABS_API_KEY=""

# Database
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD=""

# API Config
HOST="0.0.0.0"
PORT="8000"
LOG_LEVEL="info"

# SPARK Core
SPARK_WORKSPACE_DIR="C:\Users\itzme\Downloads\S.P.A.R.K" # Windows example
# SPARK_WORKSPACE_DIR="/home/user/workspace/S.P.A.R.K" # Linux/macOS example
SPARK_HOST="0.0.0.0"
SPARK_PORT="8000"
OLLAMA_MODEL="deepseek-r1:latest"

# ============================================================================
# Globe Intelligence API — Optional Keyed Data Sources
# ============================================================================
# All keys below are OPTIONAL. The Globe Monitor works without them,
# but enabling a key unlocks richer data for that layer/provider.
# Copy this file to .env and fill in the keys you want.
# ============================================================================

# ── Conflict Data ────────────────────────────────────────────────────────────
# ACLED (Armed Conflict Location & Event Data)
# Free for researchers & journalists. Register at: https://acleddata.com/
# When set: replaces GDELT artgeo with precise geocoded conflict events + fatality counts.
ACLED_ACCESS_TOKEN=""
ACLED_EMAIL=""       # required by ACLED alongside the token

# ── Market Data ──────────────────────────────────────────────────────────────
# Finnhub (stock & ETF quotes: SPY, QQQ, GLD, OIL)
# Free tier: 60 req/min. Register at: https://finnhub.io/
# When set: adds equity / commodity quotes to the market ticker.
FINNHUB_API_KEY=""

# ── Energy Data ──────────────────────────────────────────────────────────────
# U.S. Energy Information Administration (WTI crude oil price)
# Free, unlimited. Register at: https://www.eia.gov/opendata/
# When set: adds real WTI oil price to the market ticker.
EIA_API_KEY=""

# ── Wildfire / Fire Detections ────────────────────────────────────────────────
# NASA FIRMS (Fire Information for Resource Management System)
# Free. Register at: https://firms.modaps.eosdis.nasa.gov/
# When set: replaces NASA EONET fallback with high-res VIIRS SNPP detections.
NASA_FIRMS_API_KEY=""

# ── Internet Outage Layer ─────────────────────────────────────────────────────
# Cloudflare Radar API (requires free Cloudflare account with Radar access)
# Docs: https://developers.cloudflare.com/radar/
# When set: unlocks the infrastructure/internet-outage layer on the globe.
CLOUDFLARE_API_TOKEN=""

# ── Aircraft Tracking (Rate Limit Upgrade) ───────────────────────────────────
# OpenSky Network OAuth2 credentials
# Higher rate limits for cloud/server IPs vs. anonymous access.
# Register at: https://opensky-network.org/
# When set: uses Basic Auth for OpenSky → significantly higher rate limits.
OPENSKY_CLIENT_ID=""
OPENSKY_CLIENT_SECRET=""
